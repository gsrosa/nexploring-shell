{
  "name": "atlas-shell",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:atlas-ui": "npm run build --prefix ../atlas-ui",
    "dev:fresh": "rm -rf node_modules/.vite && vite",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@gsrosa/atlas-ui": "file:../atlas-ui",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.15.1",
    "@trpc/react-query": "^11.15.1",
    "atlas-bff": "file:../atlas-bff",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.4.1"
  }
}
