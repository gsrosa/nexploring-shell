{
  "name": "nexploring-shell",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:nexploring-ui": "npm run build --prefix ../nexploring-ui",
    "prepare": "husky",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"app/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:trpc": "npx tsx scripts/generate-trpc.ts",
    "precommit:staged": "lint-staged"
  },
  "dependencies": {
    "@gsrosa/nexploring-ui": "1.0.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.15.1",
    "@trpc/react-query": "^11.15.1",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "dotenv": "^17.4.2",
    "i18next": "^26.0.5",
    "i18next-http-backend": "^3.0.4",
    "lucide-react": "^1.8.0",
    "next": "^15.3.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "vitest related --run"
    ]
  }
}
